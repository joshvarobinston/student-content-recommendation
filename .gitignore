.env
.env.local
.env.production
.env.development

# ── Python ────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# ── Virtual Environment ───────────────────
venv/
env/
ENV/
.venv/
.env/

# ── Django ────────────────────────────────
*.log
db.sqlite3
*.sqlite3
media/
staticfiles/
local_settings.py

# ── Distribution / Build ──────────────────
dist/
build/
*.egg-info/
*.egg
wheels/
pip-wheel-metadata/
share/python-wheels/

# ── Testing ───────────────────────────────
.tox/
.coverage
.coverage.*
.cache
coverage.xml
*.cover
htmlcov/
.pytest_cache/

# ── Node / React Frontend ─────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
build/
.next/
.nuxt/

# ── IDE / Editors ─────────────────────────
